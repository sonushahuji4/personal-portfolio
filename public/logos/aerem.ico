<script>  
  // Genie Content Trigger
  document.addEventListener("DOMContentLoaded", function () {  
    const widget = document.getElementById("genie-widget");
    const toggleButton = document.getElementById("genie-toggle-button");
    const genieImageDesktop = document.getElementById("solar-genie-right");
    const genieImageMobile = document.getElementById("solar-genie-left");

    if (!toggleButton || !widget) return;
	if (!genieImageDesktop || !genieImageMobile) return;

    function adjustWidgetSize() {
      if (window.innerWidth >= 1024) {
        widget.style.width = "43vw";
        widget.style.height = "68vh";
        widget.style.right = "1rem";
        widget.style.borderRadius = "0.875rem 0.875rem 0 0";
        toggleButton.style.flexDirection = "row";
        genieImageMobile.style.display = "none";
        genieImageMobile.style.visibility = "hidden";
        genieImageDesktop.style.display = "block";
        genieImageDesktop.style.visibility = "visible";
      } else if (window.innerWidth > 768) {
        widget.style.width = "50vw";
        widget.style.height = "70vh";
        widget.style.right = "1rem";
        widget.style.borderRadius = "0.875rem 0.875rem 0 0";
        toggleButton.style.flexDirection = "row";
        genieImageMobile.style.display = "none";
        genieImageMobile.style.visibility = "hidden";
        genieImageDesktop.style.display = "block";
        genieImageDesktop.style.visibility = "visible";
      } else if (window.innerWidth > 640) {
        widget.style.width = "65vw";
        widget.style.height = "70vh";
        widget.style.right = "1rem";
        widget.style.borderRadius = "0.875rem 0.875rem 0 0";
        toggleButton.style.flexDirection = "row";
        genieImageMobile.style.display = "none";
        genieImageMobile.style.visibility = "hidden";
        genieImageDesktop.style.display = "block";
        genieImageDesktop.style.visibility = "visible";
      } else {
        widget.style.width = "100%";
        widget.style.height = "100%";
        widget.style.right = "0";
        widget.style.borderRadius = "0";
        toggleButton.style.flexDirection = "row-reverse";
        genieImageDesktop.style.display = "none";
        genieImageDesktop.style.visibility = "hidden";
        genieImageMobile.style.display = "block";
        genieImageMobile.style.visibility = "visible";
      }
    }
    
    function openSolarGenieWidget () { 
      const isVisible = widget.style.opacity === "1"; 
      if (isVisible) { 
        document.body.style.overflow = "auto";
        widget.style.opacity = "0"; 
        toggleButton.style.opacity = "1"; 
        widget.style.visibility = "hidden";
        widget.style.transform = "translateY(100%)"; 
        widget.style.zIndex = "0"; 
      } else { 
        widget.style.opacity = "1"; 
        toggleButton.style.opacity = "0"; 
        widget.style.transform = "translateY(0%)"; 
        widget.style.visibility = "visible"; 
        widget.style.zIndex = "99999"; 
        document.body.style.overflow = "hidden";
        if(webengage) { 
          webengage.track("SG-UserPopupClick", { "Action": "SolarGenie widget is opened." }); 
        }
      } 
    }
    const STORAGE_KEY = "solarGenieVisited";
    const EXPIRY_TIME = 30 * 60 * 1000; // 30 minutes in milliseconds
    const now = Date.now();

    const storedData = localStorage.getItem(STORAGE_KEY);

  	// If not visited recently, trigger widget
  	setTimeout(() => {
      const isInvisible = widget.style.opacity === "0";
      if (isInvisible) {
        if(storedData) {
          const { value, timestamp } = JSON.parse(storedData);
          if (value === "true" && now - timestamp < EXPIRY_TIME) {
            return;
          }
        }
		openSolarGenieWidget();
        localStorage.setItem(STORAGE_KEY, JSON.stringify({
          value: "true",
          timestamp: now
        }));
      }
  	}, 300);
    
   	 adjustWidgetSize();
	
    // Handle SolarGenie visibility toggle (with transition effect).
    toggleButton.addEventListener("click", openSolarGenieWidget);
    
    // Handle outside click
    document.addEventListener("click", function (e) {
      const isClickInside = widget.contains(e.target) || toggleButton.contains(e.target);
      const isVisible = widget.style.opacity === "1";

      if (!isClickInside && isVisible) {
        document.body.style.overflow = "auto";
        widget.style.opacity = "0";
        toggleButton.style.opacity = "1";
        widget.style.transform = "translateY(100%)";
        widget.style.visibility = "hidden";
        widget.style.zIndex = "0";
      }
    });
    
    // Handle Close CTA.
    const interval = setInterval(() => {
      const widgetCloseButton = document.getElementById("genie-close-button");
      if (widgetCloseButton) {
        widgetCloseButton.addEventListener("click", function () {
          widget.style.opacity = "0";
          toggleButton.style.opacity = "1";
          widget.style.visibility = "hidden";
          widget.style.transform = "translateY(100%)";
          widget.style.zIndex = "0";
        });
        clearInterval(interval);
      }
    }, 100);
    
  	// Genie Widget height-width responsiveness.
	window.addEventListener("resize", adjustWidgetSize);
    window.addEventListener("message", function (event) {
      if (event.data?.type === "CLOSE_WIDGET") {
        const widget = document.getElementById("genie-widget");
        if (widget) {
          widget.style.opacity = "0";
          toggleButton.style.opacity = "1";
          widget.style.visibility = "hidden";
          widget.style.transform = "translateY(100%)";
          widget.style.zIndex = "0";
        }
   	}
});

  });
</script>
-->
