  const matchPath = (pathname, route) => {
  if (route.includes(":")) {
    // Convert path with dynamic segments into a regex
    const routeRegex = new RegExp(`^${route.replace(/:\w+/g, "[^/]+")}$`);
    return routeRegex.test(pathname);
  }
  return pathname === route; // Exact match for static paths
};

// Find the page ID
const pageID = pages.find((item) => matchPath(window.location.pathname, item.path));


  
      // loginBtn
    const loginBtn = document.getElementById("loginBtn");
